<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos existentes -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Permiso para overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- ============================================ -->
    <!-- QUERIES: Permitir consultar apps externas (Android 11+) -->
    <!-- ============================================ -->
    <queries>
        <!-- Mensajería -->
        <package android:name="com.whatsapp" />
        <package android:name="org.telegram.messenger" />
        
        <!-- Redes sociales -->
        <package android:name="com.facebook.katana" />
        <package android:name="com.instagram.android" />
        <package android:name="com.twitter.android" />
        
        <!-- Multimedia -->
        <package android:name="com.google.android.youtube" />
        <package android:name="com.spotify.music" />
        <package android:name="com.zhiliaoapp.musically" />

	<!-- Netflix -->
	<package android:name="com.netflix.mediaclient" />
        
        <!-- Navegación y utilidades -->
        <package android:name="com.android.chrome" />
        <package android:name="com.google.android.apps.maps" />
        <package android:name="com.android.camera2" />
        <package android:name="com.google.android.deskclock" />
        <package android:name="com.android.calculator2" />
        
        <!-- Sistema -->
        <package android:name="com.android.settings" />
        <package android:name="com.google.android.gm" />
    </queries>
    <!-- ============================================ -->

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"        android:label="OASIS"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
	android:theme="@style/Theme.OASIS"
        tools:targetApi="34">

        <!-- SplashActivity -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.OASIS"
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MainActivity -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"	
	    android:theme="@style/Theme.OASIS"
        <!-- OverlayService -->
        <service
            android:name=".OverlayService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- SettingsActivity -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
	    android:theme="@style/Theme.OASIS"
        <activity
            android:name=".OverlayPermissionActivity"
            android:exported="false"
	    android:theme="@style/Theme.OASIS"
        <!-- VoiceCaptureActivity -->
        <activity
            android:name=".VoiceCaptureActivity"
            android:exported="false"
	    ndroid:theme="@style/Theme.OASIS"            
	    android:excludeFromRecents="true"
            android:noHistory="true"            
	    android:taskAffinity="" />

    </application>
</manifest>
