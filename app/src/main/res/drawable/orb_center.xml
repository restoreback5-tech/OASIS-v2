<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow exterior -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:startColor="#400066ff"
                android:endColor="#000066ff"
                android:type="radial"
                android:gradientRadius="120dp" />
        </shape>
    </item>
    <!-- Círculo blanco central -->
    <item
        android:left="20dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#ffffff" />
        </shape>
    </item>
    <!-- Estrella central -->
    <item
        android:left="70dp"
        android:top="70dp"
        android:right="70dp"
        android:bottom="70dp">
        <shape android:shape="oval">
            <solid android:color="#4a90e2" />
        </shape>
    </item>
</layer-list>
