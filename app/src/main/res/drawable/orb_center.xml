    <item android:bottom="15dp" android:top="85dp" android:left="15dp" android:right="85dp"><shape android:shape="oval"><solid android:color="#CE93D8"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="85dp" android:top="15dp" android:left="15dp" android:right="85dp"><shape android:shape="oval"><solid android:color="#CE93D8"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="15dp" android:top="85dp" android:left="85dp" android:right="15dp"><shape android:shape="oval"><solid android:color="#CE93D8"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="85dp" android:top="15dp" android:left="85dp" android:right="15dp"><shape android:shape="oval"><solid android:color="#CE93D8"/><size android:width="3dp" android:height="3dp"/></shape></item>

    <!-- Grupo 7: Intermedios Exteriores -->
    <item android:bottom="5dp" android:top="95dp" android:left="50dp" android:right="50dp"><shape android:shape="oval"><solid android:color="#80AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="95dp" android:top="5dp" android:left="50dp" android:right="50dp"><shape android:shape="oval"><solid android:color="#80AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="50dp" android:top="50dp" android:left="5dp" android:right="95dp"><shape android:shape="oval"><solid android:color="#80AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="50dp" android:top="50dp" android:left="95dp" android:right="5dp"><shape android:shape="oval"><solid android:color="#80AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>

    <!-- Grupo 8: Resto de diagonales externas -->
    <item android:bottom="25dp" android:top="75dp" android:left="25dp" android:right="75dp"><shape android:shape="oval"><solid android:color="#66AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="75dp" android:top="25dp" android:left="25dp" android:right="75dp"><shape android:shape="oval"><solid android:color="#66AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="25dp" android:top="75dp" android:left="75dp" android:right="25dp"><shape android:shape="oval"><solid android:color="#66AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>
    <item android:bottom="75dp" android:top="25dp" android:left="75dp" android:right="25dp"><shape android:shape="oval"><solid android:color="#66AB47BC"/><size android:width="3dp" android:height="3dp"/></shape></item>

</layer-list>
