<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Núcleo brillante -->
    <item android:bottom="50dp" android:top="50dp" android:left="50dp" android:right="50dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerColor="#FFFFFF"
                android:endColor="#00BFFF"
                android:gradientRadius="100%" />
        </shape>
    </item>

    <!-- Partículas internas -->
    <item android:bottom="78dp" android:top="78dp" android:left="10dp" android:right="90dp">
        <shape android:shape="oval">
            <solid android:color="#80FFFFFF"/> <!-- blanco translúcido -->
            <size android:width="2dp" android:height="2dp"/>
        </shape>
    </item>
    <item android:bottom="25dp" android:top="75dp" android:left="75dp" android:right="25dp">
        <shape android:shape="oval">
            <solid android:color="#8000E5FF"/> <!-- turquesa translúcido -->
            <size android:width="2dp" android:height="2dp"/>
        </shape>
    </item>

    <!-- Partículas externas -->
    <item android:bottom="95dp" android:top="5dp" android:left="50dp" android:right="50dp">
        <shape android:shape="oval">
            <solid android:color="#66AB47BC"/> <!-- púrpura tenue -->
            <size android:width="2dp" android:height="2dp"/>
        </shape>
    </item>
    <item android:bottom="25dp" android:top="75dp" android:left="25dp" android:right="75dp">
        <shape android:shape="oval">
            <solid android:color="#66BA68C8"/> <!-- magenta translúcido -->
            <size android:width="2dp" android:height="2dp"/>
        </shape>
    </item>

</layer-list>
