<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ============================================
         NÚCLEO DEL ORB (Esfera central)
         ============================================ -->
    <item android:bottom="45dp" android:top="45dp" android:left="45dp" android:right="45dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerColor="#FFFFFF"
                android:endColor="#00BFFF"
                android:gradientRadius="100%" />
        </shape>
    </item>

    <!-- ============================================
         PARTÍCULAS FLOTANTES (Densa nube de puntos)
         ============================================ -->
    
    <!-- Partículas Capa 1 (Cerca del centro - Turquesa) -->
    <item android:bottom="20dp" android:top="60dp" android:left="35dp" android:right="65dp">
        <shape android:shape="oval">
            <solid android:color="#00E5FF" />
            <size android:width="6dp" android:height="6dp" />
        </shape>
    </item>
    
    <item android:bottom="35dp" android:top="45dp" android:left="65dp" android:right="35dp">
        <shape android:shape="oval">
            <solid android:color="#00E5FF" />
            <size android:width="5dp" android:height="5dp" />
        </shape>
    </item>
    
    <item android:bottom="65dp" android:top="20dp" android:left="45dp" android:right="55dp">
        <shape android:shape="oval">
            <solid android:color="#00ACC1" />
            <size android:width="6dp" android:height="6dp" />
        </shape>
    </item>
    
    <item android:bottom="50dp" android:top="35dp" android:left="25dp" android:right="75dp">
        <shape android:shape="oval">
            <solid android:color="#4DD0E5" />
            <size android:width="5dp" android:height="5dp" />
        </shape>
    </item>
    <!-- Partículas Capa 2 (Media distancia - Magenta/Púrpura) -->
    <item android:bottom="10dp" android:top="75dp" android:left="50dp" android:right="50dp">
        <shape android:shape="oval">
            <solid android:color="#AB47BC" />
            <size android:width="5dp" android:height="5dp" />
        </shape>
    </item>
    
    <item android:bottom="75dp" android:top="10dp" android:left="60dp" android:right="40dp">
        <shape android:shape="oval">
            <solid android:color="#BA68C8" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>
    
    <item android:bottom="40dp" android:top="45dp" android:left="10dp" android:right="90dp">
        <shape android:shape="oval">
            <solid android:color="#AB47BC" />
            <size android:width="5dp" android:height="5dp" />
        </shape>
    </item>
    
    <item android:bottom="45dp" android:top="40dp" android:left="90dp" android:right="10dp">
        <shape android:shape="oval">
            <solid android:color="#4DD0E5" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>

    <!-- Partículas Capa 3 (Exteriores - Más dispersas) -->
    <item android:bottom="5dp" android:top="80dp" android:left="25dp" android:right="75dp">
        <shape android:shape="oval">
            <solid android:color="#8000E5FF" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>
    
    <item android:bottom="80dp" android:top="5dp" android:left="75dp" android:right="25dp">
        <shape android:shape="oval">
            <solid android:color="#80AB47BC" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>
    
    <item android:bottom="15dp" android:top="70dp" android:left="80dp" android:right="20dp">
        <shape android:shape="oval">
            <solid android:color="#6600E5FF" />
            <size android:width="5dp" android:height="5dp" />
        </shape>
    </item>    
    <item android:bottom="70dp" android:top="15dp" android:left="15dp" android:right="85dp">
        <shape android:shape="oval">
            <solid android:color="#66AB47BC" />
            <size android:width="5dp" android:height="5dp" />
        </shape>
    </item>

    <!-- Partículas adicionales (Densidad extra) -->
    <item android:bottom="30dp" android:top="55dp" android:left="70dp" android:right="30dp">
        <shape android:shape="oval">
            <solid android:color="#4DC1FF" />
            <size android:width="3dp" android:height="3dp" />
        </shape>
    </item>
    
    <item android:bottom="55dp" android:top="30dp" android:left="30dp" android:right="70dp">
        <shape android:shape="oval">
            <solid android:color="#4DAB47BC" />
            <size android:width="3dp" android:height="3dp" />
        </shape>
    </item>
    
    <item android:bottom="25dp" android:top="60dp" android:left="55dp" android:right="45dp">
        <shape android:shape="oval">
            <solid android:color="#8000BFFF" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>
    
    <item android:bottom="60dp" android:top="25dp" android:left="40dp" android:right="60dp">
        <shape android:shape="oval">
            <solid android:color="#8000E5FF" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>

</layer-list>
