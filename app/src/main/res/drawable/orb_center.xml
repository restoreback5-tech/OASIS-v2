<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Partículas Exteriores (Cian Roto) -->
    <item android:bottom="15dp" android:top="15dp" android:left="15dp" android:right="15dp">
        <shape android:shape="oval">
            <stroke android:width="4dp" android:color="#00E5FF" 
                android:dashWidth="6dp" android:dashGap="10dp" />
        </shape>
    </item>

    <!-- Partículas Intermedias (Magenta Roto) -->
    <item android:bottom="25dp" android:top="25dp" android:left="25dp" android:right="25dp">
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="#AB47BC" 
                android:dashWidth="4dp" android:dashGap="15dp" />
        </shape>
    </item>

    <!-- Núcleo Sólido (El ojo) -->
    <item android:bottom="45dp" android:top="45dp" android:left="45dp" android:right="45dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

</layer-list>
