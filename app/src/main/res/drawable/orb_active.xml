<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<!-- 1. Aura Exterior (Verde Energía con borde oscuro) -->
<item>
<shape android:shape="oval">
<gradient
android:type="radial"
android:centerColor="#8000CC66"
android:endColor="#20000000"
android:gradientRadius="120dp" />
</shape>
</item>

<!-- 2. Capa Intermedia (Verde Neón Intenso) -->
<item android:bottom="10dp" android:top="10dp" android:left="10dp" android:right="10dp">
<shape android:shape="oval">
<gradient
android:type="radial"
android:centerColor="#00FF66"
android:endColor="#006633"
android:gradientRadius="80dp" />
</shape>
</item>

<!-- 3. Anillo Negro (Toque oscuro - contraste) -->
<item android:bottom="25dp" android:top="25dp" android:left="25dp" android:right="25dp">
<shape android:shape="oval">
<stroke android:width="5dp" android:color="#CC000000" />
<solid android:color="#00000000" />
</shape>
</item>

<!-- 4. Núcleo (Verde Blanco Brillante - Centro Activo) -->
<item android:bottom="45dp" android:top="45dp" android:left="45dp" android:right="45dp">
<shape android:shape="oval">
<gradient
android:type="radial"
android:centerColor="#CCFFCC"
android:endColor="#00CC66"
android:gradientRadius="35dp" />
</shape>
</item>
</layer-list>
