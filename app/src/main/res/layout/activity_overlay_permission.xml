<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_translucent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Icono -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_launcher"
            android:layout_marginBottom="32dp"
            android:contentDescription="OASIS" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permiso de superposición"
            android:textSize="24sp"
            android:textColor="#1C1C1E"
            android:fontFamily="@font/sf_pro_display_medium"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Explicación -->
        <TextView
            android:id="@+id/text_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#3A3A3C"
            android:fontFamily="@font/sf_pro_display_regular"
            android:lineSpacingExtra="4dp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Botón: Conceder permiso -->
        <Button
            android:id="@+id/btn_grant_permission"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Abrir configuración"
            android:textSize="16sp"
            android:backgroundTint="#39FF14"
            android:textColor="#000000"
            android:fontFamily="@font/sf_pro_display_medium"
            android:layout_marginBottom="16dp" />

        <!-- Botón: Más tarde -->
        <Button
            android:id="@+id/btn_later"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ahora no"
            android:textSize="16sp"
            android:backgroundTint="#8E8E93"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/googlesans_medium" />

    </LinearLayout>
</ScrollView>
