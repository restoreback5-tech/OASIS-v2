<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <!-- Reloj -->
    <TextView
        android:id="@+id/clock_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="9:41"
        android:textSize="64sp"
        
        android:fontFamily="@font/sf_pro_display_bold"
        android:layout_marginTop="32dp" />

   <!-- Icono de ajustes (engrane) -->
   <ImageView
    android:id="@+id/btn_settings"
    android:layout_width="48dp"
    android:layout_height="48dp"
    android:src="@android:drawable/ic_menu_preferences"
    android:contentDescription="Ajustes"
    android:layout_alignParentEnd="true"
    android:layout_marginTop="32dp"
    android:layout_marginEnd="16dp"
    android:padding="8dp"
    android:background="?attr/selectableItemBackgroundBorderless"
    android:tint="#FFFFFF" />

    <!-- Orbe central -->
    <ImageView
        android:id="@+id/orb_view"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/orb_center"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp" />

    <!-- Texto de saludo/debug -->
    <TextView
        android:id="@+id/greeting_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OASIS"
        android:textSize="20sp"
        
        android:layout_marginBottom="32dp" />

    <!-- Debug text -->
    <TextView
        android:id="@+id/debug_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Debug"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="#1A1A1A"
        android:visibility="gone"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Fila 1: Llamar y Mensaje -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_call"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:background="@drawable/btn_call_gradient"
            app:backgroundTint="@null"
            android:text="Llamar"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_phone"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            android:layout_marginEnd="8dp"
            android:elevation="8dp"
            android:stateListAnimator="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_message"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:background="@drawable/btn_message_gradient"
            app:backgroundTint="@null"
            android:text="Enviar mensaje"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_message"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            android:layout_marginStart="8dp"
            android:elevation="8dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Fila 2: Contactos y Apps -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_contacts"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:background="@drawable/btn_contacts_gradient"
            app:backgroundTint="@null"
            android:text="Contactos"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_contacts"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            android:layout_marginEnd="8dp"
            android:elevation="8dp"
            android:stateListAnimator="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apps"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:background="@drawable/btn_apps_gradient"
            android:text="Apps"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:icon="@drawable/ic_apps"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            android:layout_marginStart="8dp"
            android:elevation="8dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
