<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient">

    <!-- Reloj -->
    <TextView
        android:id="@+id/clock_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="9:41"
        android:textSize="48sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <!-- Orbe central -->
    <ImageView
        android:id="@+id/orb_view"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/orb_center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/clock_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Texto de saludo -->
    <TextView
        android:id="@+id/greeting_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hola, ¿en qué puedo ayudarte?"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/orb_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botones -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_call"        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="Llamar"
        android:textSize="16sp"
        app:icon="@drawable/ic_phone"
        app:iconGravity="textTop"
        app:iconSize="32dp"
        android:layout_margin="12dp"
        app:cornerRadius="40dp"
        app:backgroundTint="@color/btn_call"
        app:layout_constraintTop_toBottomOf="@id/greeting_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_message"
        app:layout_constraintHorizontal_chainStyle="spread" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_message"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="Enviar mensaje"
        android:textSize="16sp"
        app:icon="@drawable/ic_message"
        app:iconGravity="textTop"
        app:iconSize="32dp"
        android:layout_margin="12dp"
        app:cornerRadius="40dp"
        app:backgroundTint="@color/btn_message"
        app:layout_constraintTop_toBottomOf="@id/greeting_text"
        app:layout_constraintStart_toEndOf="@id/btn_call"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_contacts"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="Contactos"
        android:textSize="16sp"
        app:icon="@drawable/ic_contacts"
        app:iconGravity="textTop"
        app:iconSize="32dp"
        android:layout_margin="12dp"
        app:cornerRadius="40dp"
        app:backgroundTint="@color/btn_contacts"
        app:layout_constraintTop_toBottomOf="@id/btn_call"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_apps" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apps"
        android:layout_width="0dp"        android:layout_height="80dp"
        android:text="apps"
        android:textSize="16sp"
        app:icon="@drawable/ic_apps"
        app:iconGravity="textTop"
        app:iconSize="32dp"
        android:layout_margin="12dp"
        app:cornerRadius="40dp"
        app:backgroundTint="@color/btn_apps"
        app:layout_constraintTop_toBottomOf="@id/btn_message"
        app:layout_constraintStart_toEndOf="@id/btn_contacts"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
