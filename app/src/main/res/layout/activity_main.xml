<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <!-- Icono de ajustes (engrane) - Esquina superior derecha -->
    <ImageView
    android:id="@+id/btn_settings"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:layout_alignParentTop="true"
    android:layout_alignParentEnd="true"
    android:layout_margin="16dp"
    android:src="@android:drawable/ic_menu_preferences"
    android:contentDescription="Ajustes"
    android:padding="12dp"
    android:background="?attr/selectableItemBackgroundBorderless"
    android:tint="#000000" 
    android:elevation="4dp" />

    <!-- Reloj (oculto por defecto) -->
    <TextView
        android:id="@+id/clock_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="9:41"
        android:textSize="64sp"
        android:fontFamily="@font/sf_pro_display_bold"
        android:visibility="gone" />

    <!-- Orbe central - CENTRADO VERTICALMENTE -->
    <ImageView
        android:id="@+id/orb_view"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_centerInParent="true"
        android:src="@drawable/orb_center"
        android:layout_marginBottom="24dp" />

    <!-- Texto de saludo - Debajo del orbe -->
    <TextView
        android:id="@+id/greeting_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/orb_view"        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:text="OASIS"
        android:textSize="20sp" />

    <!-- Debug text (oculto por defecto) -->
    <TextView
        android:id="@+id/debug_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/greeting_text"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:background="#1A1A1A"
        android:gravity="center"
        android:padding="8dp"
        android:text="🔍 Debug"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Fila 1: Llamar y Mensaje - Debajo del saludo -->
    <LinearLayout
        android:id="@+id/row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/debug_text"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_call"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_call_gradient"
            android:stateListAnimator="@null"
            android:text="Llamar"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_phone"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_message"
            android:layout_width="0dp"            android:layout_height="70dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_message_gradient"
            android:stateListAnimator="@null"
            android:text="Enviar mensaje"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_message"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF" />
    </LinearLayout>

    <!-- Fila 2: Contactos y Apps - Debajo de la fila 1 -->
    <LinearLayout
        android:id="@+id/row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/row_1"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_contacts"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_contacts_gradient"
            android:stateListAnimator="@null"
            android:text="Contactos"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_contacts"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apps"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_apps_gradient"
            android:stateListAnimator="@null"
            android:text="Apps"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:icon="@drawable/ic_apps"            app:iconGravity="textStart"
            app:iconTint="#FFFFFF" />
    </LinearLayout>

</RelativeLayout>
