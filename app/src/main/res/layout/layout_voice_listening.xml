<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/bg_translucent"
    android:elevation="8dp">

    <ImageView
        android:id="@+id/img_listening_indicator"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/led_indicator"
        android:tint="#39FF14"
        android:contentDescription="Escuchando" />

    <TextView
        android:id="@+id/txt_listening_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Escuchando..."
        android:textSize="16sp"
        android:textColor="#1C1C1E"
        android:fontFamily="@font/googlesans_medium" />
</LinearLayout>
