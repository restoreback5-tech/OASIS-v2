<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Volver"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#1C1C1E" />

            <TextView
                android:id="@+id/settings_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ajustes"
                android:textSize="24sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_semibold"
                android:gravity="center" />

            <View
                android:layout_width="48dp"
                android:layout_height="48dp" />
        </LinearLayout>

        <!-- 0. Ocultar reloj -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_hide_clock"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador ocultar reloj" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_hide_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Ocultar reloj: No"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <!-- 1. Formato de reloj -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_clock_format"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador formato de reloj" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_clock_format"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Formato de reloj: 24h"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <!-- 2. Sonidos UI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_sounds"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador sonidos" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_sounds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Sonidos: Activados"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <!-- 3. Voz TTS (nuevo) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_tts_enabled"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador voz TTS" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_tts_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Voz asistente: Activada"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <!-- 4. Tema (tres iconos) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/theme_sol"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_sol"
                        android:contentDescription="Sol" />

                    <ImageView
                        android:id="@+id/indicator_sol"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_check_circle_blue"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/theme_luna"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_luna"
                        android:contentDescription="Luna" />

                    <ImageView
                        android:id="@+id/indicator_luna"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_check_circle_blue"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/theme_nubes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_nubes"
                        android:contentDescription="Nubes" />

                    <ImageView
                        android:id="@+id/indicator_nubes"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_check_circle_blue"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/text_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Tema: Amanecer"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp" />

        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <!-- 5. Asistente flotante -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_overlay"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador asistente flotante" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_overlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Asistente flotante: Desactivado"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <!-- 6. Velocidad de voz -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/led_tts_speed"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/led_indicator"
                        android:contentDescription="Indicador velocidad de voz" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Velocidad de voz"
                    android:textSize="16sp"
                    android:textColor="#1C1C1E"
                    android:fontFamily="@font/googlesans_medium" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbar_tts_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="56dp"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/settings_accent_blue"
                android:thumbTint="@color/settings_accent_blue" />

            <TextView
                android:id="@+id/text_tts_speed_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Normal"
                android:textSize="14sp"
                android:textColor="#1C1C1E"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginStart="56dp" />
        </LinearLayout>

        <!-- 7. Tono de voz -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/led_tts_pitch"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/led_indicator"
                        android:contentDescription="Indicador tono de voz" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Tono de voz"
                    android:textSize="16sp"
                    android:textColor="#1C1C1E"
                    android:fontFamily="@font/googlesans_medium" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbar_tts_pitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="56dp"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/settings_accent_blue"
                android:thumbTint="@color/settings_accent_blue" />

            <TextView
                android:id="@+id/text_tts_pitch_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Normal"
                android:textSize="14sp"
                android:textColor="#1C1C1E"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginStart="56dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
