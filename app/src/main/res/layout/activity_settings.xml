<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_translucent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Volver"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#1C1C1E" />

            <TextView
                android:id="@+id/settings_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ajustes"
                android:textSize="24sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_semibold"
                android:gravity="center" />

            <View
                android:layout_width="48dp"
                android:layout_height="48dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_clock_format"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador formato de reloj"
                    android:tint="#39FF14" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Formato de reloj: 24h"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_tts_speed"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador velocidad de voz"
                    android:tint="#39FF14" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Velocidad de voz: Normal"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_sounds"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador sonidos"
                    android:tint="#39FF14" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Sonidos: Activados"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_animations"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador animaciones"
                    android:tint="#39FF14" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Animaciones: Activadas"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/led_day_night"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/led_indicator"
                    android:contentDescription="Indicador modo día/noche"
                    android:tint="#39FF14" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Modo Día/Noche: Día"
                android:textSize="16sp"
                android:textColor="#1C1C1E"
                android:fontFamily="@font/googlesans_medium" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E5EA"/>

    </LinearLayout>
</ScrollView>
